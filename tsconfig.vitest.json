{
  "extends": "./tsconfig.json",
  "include": [
    "src/**/*.test.ts",
    "src/shared/**/*.ts",
    "src/main/**/*.ts",
    "src/preload/**/*.ts",
    "src/renderer/apps/**/*.ts"
  ],
  "compilerOptions": {
    "composite": true,
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Node",
    "lib": ["ES2022"],
    "types": ["node", "vitest/globals"],
    "baseUrl": "."
  }
}
