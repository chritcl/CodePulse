{
  "name": "codepulse",
  "version": "0.1.0",
  "description": "Windows 本地 AI Agent 状态助手",
  "author": "CodePulse",
  "private": true,
  "main": "dist/main/index.js",
  "type": "commonjs",
  "packageManager": "pnpm@11.7.0",
  "scripts": {
    "dev:renderer": "vite --host 127.0.0.1",
    "build:node": "tsc -p tsconfig.node.json",
    "build:renderer": "vite build",
    "typecheck": "vue-tsc -p tsconfig.app.json --noEmit && tsc -p tsconfig.node.json --noEmit && tsc -p tsconfig.vitest.json --noEmit",
    "test": "vitest run --config vite.config.ts",
    "build": "pnpm run typecheck && pnpm run test && pnpm run build:node && pnpm run build:renderer",
    "start": "pnpm run build && electron .",
    "dist": "pnpm run build && electron-builder"
  },
  "pnpm": {
    "ignoredBuiltDependencies": [
      "electron-winstaller"
    ]
  },
  "dependencies": {
    "echarts": "^6.1.0",
    "element-plus": "^2.14.2",
    "pinia": "^3.0.4",
    "sql.js": "^1.14.1",
    "vue": "^3.5.39",
    "vue-router": "^5.1.0"
  },
  "devDependencies": {
    "@types/node": "^26.0.1",
    "@types/sql.js": "^1.4.11",
    "@vitejs/plugin-vue": "^6.0.7",
    "electron": "^42.5.1",
    "electron-builder": "^25.1.8",
    "typescript": "^6.0.3",
    "vite": "^8.1.0",
    "vitest": "^4.1.9",
    "vue-tsc": "^3.3.5"
  }
}
